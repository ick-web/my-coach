# Supabase 프로젝트 설정
# Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# AI 서빙 서버 (FastAPI — 스케줄 생성, 회고 피드백)
EXPO_PUBLIC_AI_API_URL=http://localhost:8000

# Google OAuth 2.0 클라이언트 ID
# https://console.cloud.google.com → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=

# 카카오 REST API 키
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
EXPO_PUBLIC_KAKAO_REST_API_KEY=

# 카카오 Client Secret은 클라이언트에 절대 포함하지 않는다.
# Supabase auth-kakao Edge Function 시크릿(KAKAO_REST_API_KEY, KAKAO_CLIENT_SECRET)으로만 설정.
# Dashboard → Edge Functions → auth-kakao → Secrets

# Apple Sign In은 앱 내 expo-apple-authentication SDK로 처리 (별도 환경변수 불필요)
# Xcode에서 Signing & Capabilities → Sign In with Apple 활성화 필요
